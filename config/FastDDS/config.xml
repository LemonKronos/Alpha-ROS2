<?xml version="1.0" encoding="UTF-8" ?>
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">

    <transport_descriptors>
        <transport_descriptor>
            <transport_id>shm_transport</transport_id>
            <type>SHM</type>
            <segment_size>268435456</segment_size>
            <port_queue_capacity>1024</port_queue_capacity>
        </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="SHMParticipant" is_default_profile="true">
        <rtps>
            <useBuiltinTransports>true</useBuiltinTransports>
            <userTransports>
                <transport_id>shm_transport</transport_id>
            </userTransports>
        </rtps>
    </participant>

    <data_writer profile_name="SHMDataWriter" is_default_profile="true">
        <qos>
            <data_sharing>
                <kind>AUTO</kind>
            </data_sharing>
        </qos>
    </data_writer>

    <data_reader profile_name="SHMDataReader" is_default_profile="true">
        <qos>
            <data_sharing>
                <kind>AUTO</kind>
            </data_sharing>
        </qos>
    </data_reader>

</profiles>