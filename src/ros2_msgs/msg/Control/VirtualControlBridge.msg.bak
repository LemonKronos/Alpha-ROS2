# Topic act as a front-end back-end bridge

std_msgs/Header header

# Body velocity in ROS2 FLU frame (m/s)
float32 vf     # Forward
float32 vl     # Left
float32 vu     # Up

# World position in ROS2 ENU frame (m from HOME)
bool use_position # If true, use position below instead of velocity above
float32 pe # East
float32 pn # North
float32 pu # Up

float32 yawspeed    # Yawspeed top down/ yaw to left (rad/s)
float32 yaw # Yaw top down / yaw from North (-PI ... +PI)