#!/usr/bin/env python3
"""
Refactored ROS2 node for Pygame virtual joystick UI.
Separates UI input from ROS2 publishing, normalizes input at source, and publishes at 30Hz.
"""
import pygame
import rclpy
from rclpy.node import Node
from ros2_msgs.msg import ControlInterface
from typing import Tuple


# Constants
HUMAN = 0
UNCHANGE = 0


class PygameController:
    """
    Handles Pygame input and computes normalized control values in range [-1, 1].
    """
    def __init__(self, width: int = 400, height: int = 400):
        pygame.init()
        self.width = width
        self.height = height
        self.screen = pygame.display.set_mode((self.width, self.height))
        pygame.display.set_caption("Virtual Joystick")
        self.clock = pygame.time.Clock()

        # Joystick parameters
        self.origin = (self.width // 2, self.height // 2)
        self.joystick_radius = 120

        # Slider parameters
        self.hslider_width, self.hslider_height = 180, 20
        self.vslider_width, self.vslider_height = 20, 180

        self.hslider_origin = (self.origin[0], self.origin[1] - self.joystick_radius - 50)
        self.vslider_origin = (self.origin[0] + self.joystick_radius + 50, self.origin[1])

    def get_input(self) -> Tuple[float, float, float, float]:
        """
        Returns normalized control values in range [-1,1]: forward, right, down, yaw.
        """
        forward = 0.0
        right = 0.0
        down = 0.0
        yaw = 0.0

        keys = pygame.key.get_pressed()

        # WASD movement -> forward/backward and left/right
        if keys[pygame.K_w] and not keys[pygame.K_s]:
            forward = 1.0
        elif keys[pygame.K_s] and not keys[pygame.K_w]:
            forward = -1.0

        if keys[pygame.K_e] and not keys[pygame.K_q]:
            right = 1.0
        elif keys[pygame.K_q] and not keys[pygame.K_e]:
            right = -1.0

        # Horizontal slider -> yaw (A/D keys)
        if keys[pygame.K_d] and not keys[pygame.K_a]:
            yaw = 1.0
        elif keys[pygame.K_a] and not keys[pygame.K_d]:
            yaw = -1.0

        # Vertical slider -> down/up (Space / Shift)
        if keys[pygame.K_SPACE] and not (keys[pygame.K_LSHIFT] or keys[pygame.K_RSHIFT]):
            down = -1.0
        elif (keys[pygame.K_LSHIFT] or keys[pygame.K_RSHIFT]) and not keys[pygame.K_SPACE]:
            down = 1.0

        return forward, right, down, yaw

    def draw_feedback(self, forward: float, right: float, down: float, yaw: float) -> None:
        """
        Draws simple visual feedback for joystick and sliders.
        """
        self.screen.fill((30, 30, 30))

        # Draw joystick circle
        pygame.draw.circle(self.screen, (80, 80, 80), self.origin, self.joystick_radius, 2)

        # Draw simple indicator
        joy_x = int(self.origin[0] + right * self.joystick_radius)
        joy_y = int(self.origin[1] - forward * self.joystick_radius)
        pygame.draw.circle(self.screen, (255, 0, 0), (joy_x, joy_y), 20)

        pygame.display.update()
        self.clock.tick(60)

    def process_events(self) -> bool:
        """
        Handles Pygame events. Returns False if quit event detected.
        """
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                return False
        return True


class DronePublisher(Node):
    """
    ROS2 node that publishes ControlInterface messages at a fixed rate.
    """
    def __init__(self, controller: PygameController, rate_hz: int = 30):
        super().__init__("pygame_control_node")
        self.controller = controller
        self.pub = self.create_publisher(ControlInterface, "control/final", 10)
        self.timer = self.create_timer(1.0 / rate_hz, self.publish_control)

    def publish_control(self) -> None:
        """
        Reads input from controller, builds ControlInterface message, and publishes.
        """
        forward, right, down, yaw = self.controller.get_input()

        msg = ControlInterface()
        try:
            msg.header.stamp = self.get_clock().now().to_msg()
        except AttributeError:
            pass
        msg.control_by = HUMAN
        msg.control_state = True
        msg.roll = 0.0
        msg.pitch = 0.0
        msg.yaw = float(yaw)
        msg.forward = float(forward)
        msg.right = float(right)
        msg.down = float(down)
        msg.wings_mode = UNCHANGE

        self.get_logger().debug(
            f"Publish: forward={forward} right={right} down={down} yaw={yaw}"
        )
        self.pub.publish(msg)


def main():
    rclpy.init()
    controller = PygameController()
    node = DronePublisher(controller)

    try:
        running = True
        while running:
            running = controller.process_events()
            fwd, rgt, dwn, yw = controller.get_input()
            controller.draw_feedback(fwd, rgt, dwn, yw)
            rclpy.spin_once(node, timeout_sec=0.0)
    except KeyboardInterrupt:
        node.get_logger().info("KeyboardInterrupt, shutting down")
    finally:
        node.destroy_node()
        rclpy.shutdown()
        pygame.quit()


if __name__ == "__main__":
    main()
