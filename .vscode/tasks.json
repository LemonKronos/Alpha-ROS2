{
    "version": "2.0.0",
    "tasks": [
        {"label": "Build ROS2 single Node and it Upstream",
            "type": "shell",
            "command": "source $HOME/MyCode/Project/Drone/ROS2/scripts/setupROS2Build.sh && colcon build --allow-overriding ${input:packageName} --packages-up-to ${input:packageName}",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "/bin/zsh",
                    "args": ["-l", "-c"]
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": ["$colcon-gcc"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
        },
        {"label": "Build ROS2 single Node and it Downstream",
            "type": "shell",
            "command": "source $HOME/MyCode/Project/Drone/ROS2/scripts/setupROS2Build.sh && colcon build --allow-overriding ${input:packageName} --packages-above ${input:packageName}",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "/bin/zsh",
                    "args": ["-l", "-c"]
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": ["$colcon-gcc"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
        },
        {"label": "Build ROS2 single Node, it Up and Downstream",
            "type": "shell",
            "command": "source $HOME/MyCode/Project/Drone/ROS2/scripts/setupROS2Build.sh && colcon build --allow-overriding ${input:packageName} --packages-above-and-dependencies ${input:packageName}",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "/bin/zsh",
                    "args": ["-l", "-c"]
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": ["$colcon-gcc"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
        },
        {"label": "Build ROS2 single Node Only",
            "type": "shell",
            "command": "source $HOME/MyCode/Project/Drone/ROS2/scripts/setupROS2Build.sh && colcon build --allow-overriding ${input:packageName} --packages-select ${input:packageName}",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "/bin/zsh",
                    "args": ["-l", "-c"]
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": ["$colcon-gcc"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
        },
        {"label": "Build Full ROS2 Workspace",
            "type": "shell",
            "command": "if [ \"${input:confirmFullBuild}\" = \"Yes\" ]; then source $HOME/MyCode/Project/Drone/ROS2/scripts/setupROS2Build.sh && ionice -c2 -n7 nice -n 10 colcon build ; else echo \"Cancelled\"; fi",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "/bin/zsh",
                    "args": ["-l", "-c"]
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": ["$colcon-gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {"label": "Build ROS2 Outsource",
            "type": "shell",
            "command": "source $HOME/MyCode/Project/Drone/ROS2/scripts/setupROS2Build.sh && colcon build --cmake-args -DCMAKE_POSITION_INDEPENDENT_CODE=ON --base-paths src/Out_source/${input:outsourceSub}",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "/bin/zsh",
                    "args": ["-l", "-c"]
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": ["$colcon-gcc"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
        }
    ],
    "inputs": [
        {
            "id": "packageName",
            "type": "promptString",
            "description": "Enter ROS2 package to build",
            "default": "finalize_control"
        },
        {
            "id": "confirmFullBuild",
            "type": "pickString",
            "description": "Dude U sure want to re-build full ROS2 workspace?",
            "options": ["Yes", "No"],
            "default": "No"
        },
        {
            "id": "outsourceSub",
            "type": "promptString",
            "description": "Enter Outsource sub directory to build",
            "default": "px4_msgs"
        },
    ]
}
