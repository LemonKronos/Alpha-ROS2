{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build ROS2 Single Node Debug",
            "type": "shell",
            "command": "source /opt/ros/jazzy/setup.bash && ionice -c2 -n7 nice -n 10 colcon build --symlink-install --cmake-args -DCMAKE_BUILD_TYPE=RelWithDebInfo --parallel-workers 8 --packages-up-to ${input:packageName}",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "/bin/bash",
                    "args": ["-l", "-c"]
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": ["$colcon-gcc"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
        },
        {
            "label": "Colcon Build Full ROS2 Workspace",
            "type": "shell",
            "command": "if [ \"${input:confirmFullBuild}\" = \"Yes\" ]; then source /opt/ros/jazzy/setup.bash && ionice -c2 -n7 nice -n 10 colcon build --symlink-install --cmake-args -DCMAKE_BUILD_TYPE=RelWithDebInfo --parallel-workers 8 ; else echo \"Cancelled\"; fi",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "/bin/bash",
                    "args": ["-l", "-c"]
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": ["$colcon-gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ],
    "inputs": [
        {
            "id": "packageName",
            "type": "promptString",
            "description": "Enter ROS2 package to build",
            "default": "finalize_control"
        },
        {
            "id": "confirmFullBuild",
            "type": "pickString",
            "description": "Dude U sure want to re-build full ROS2 workspace?",
            "options": ["Yes", "No"],
            "default": "Yes"
        }
    ]
}
